exports[`buildProjectLookupQuery > matches snapshot 1`] = `
"
    query SymphonyPlanProject($projectSlug: String!) {
      projects(first: 1, filter: { slugId: { eq: $projectSlug } }) {
        nodes {
          id
          name
          slugId
          teams(first: 1) {
            nodes {
              id
              name
              key
            }
          }
        }
      }
    }
  "
`;

exports[`buildTeamStatesQuery > matches snapshot 1`] = `
"
    query SymphonyTeamStates($teamId: String!) {
      team(id: $teamId) {
        id
        name
        states {
          nodes {
            id
            name
            type
          }
        }
      }
    }
  "
`;

exports[`buildTeamsQuery > matches snapshot 1`] = `
"
    query SymphonyTeams {
      teams(first: 50) {
        nodes {
          id
          name
          key
        }
      }
    }
  "
`;
