#!/bin/sh
# ── Pre-push: full CI-mirror gate ────────────────────────────────────
# Catches everything CI Phase 1 + Phase 2 would catch, locally.
# If any step fails, the push is aborted.

set -e

# Skip checks when only deleting remote branches (no code is being pushed)
z40=0000000000000000000000000000000000000000
all_deletes=true
while read local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" != "$z40" ]; then
    all_deletes=false
    break
  fi
done
if [ "$all_deletes" = true ]; then
  echo "🗑️  Branch delete only — skipping pre-push checks."
  exit 0
fi

echo "🔨 Building..."
pnpm run build

echo "🔍 Linting..."
pnpm run lint

echo "🎨 Fixing & checking formatting..."
pnpm run format
pnpm run format:check

echo "🧪 Running tests..."
pnpm test

echo "🧹 Checking for dead code..."
pnpm run knip

echo "🔍 Checking for duplicate code..."
pnpm run jscpd

echo "🎭 Running E2E smoke tests..."
pnpm exec playwright test --project=smoke

echo "🔒 Running Semgrep security scan..."
semgrep scan --config auto --config p/typescript --error

# Stryker mutation testing — only if changed files overlap with mutate targets
STRYKER_TARGETS=$(node -e "console.log(require('./stryker.config.json').mutate.join(' '))" 2>/dev/null || echo "")
CHANGED_FILES=$(git diff --name-only @{push}..HEAD 2>/dev/null || git diff --name-only HEAD~1 HEAD 2>/dev/null || true)
MUTATE_HITS=""
for target in $STRYKER_TARGETS; do
  if echo "$CHANGED_FILES" | grep -qx "$target"; then
    MUTATE_HITS="$MUTATE_HITS $target"
  fi
done
if [ -n "$MUTATE_HITS" ]; then
  echo "🧬 Running incremental mutation testing (changed targets:$MUTATE_HITS)..."
  pnpm run test:mutation:incremental
else
  echo "🧬 Skipping mutation testing — no Stryker mutate targets changed."
fi

echo "📊 Checking type coverage..."
pnpm run typecheck:coverage

echo "✅ All pre-push checks passed!"
