{
  "name": "symphony-orchestrator",
  "version": "0.6.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/OmerFarukOruc/symphony-orchestrator.git"
  },
  "homepage": "https://github.com/OmerFarukOruc/symphony-orchestrator",
  "bugs": {
    "url": "https://github.com/OmerFarukOruc/symphony-orchestrator/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "symphony": "./bin/symphony"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run build:frontend",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:docker": "vitest run tests/integration/docker-lifecycle.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project=smoke",
    "test:e2e:visual": "playwright test --project=visual",
    "test:e2e:update": "playwright test --project=visual --update-snapshots",
    "test:frontend": "vitest run --config vitest.frontend.config.ts",
    "test:mutation": "stryker run",
    "test:load": "vitest run --config vitest.load.config.ts",
    "dev": "tsx watch src/cli/index.ts",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "lint": "eslint src/ tests/ playwright.config.ts",
    "lint:fix": "eslint --fix src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts' '*.json' 'playwright.config.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts' 'playwright.config.ts'",
    "knip": "knip",
    "jscpd": "jscpd --config .jscpd.json",
    "docs:generate": "typedoc",
    "typecheck": "tsc --noEmit -p tsconfig.eslint.json",
    "typecheck:frontend": "tsc --noEmit -p frontend/tsconfig.json",
    "prepare": "husky"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "drizzle-orm": "^0.45.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.1",
    "liquidjs": "^10.25.1",
    "pino": "^9.6.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/autocannon": "^7.12.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.0",
    "agentation": "^2.3.3",
    "agentation-mcp": "^1.2.0",
    "autocannon": "^8.0.0",
    "codemirror": "^6.0.2",
    "eslint": "^10.1.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "fast-check": "^4.6.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "knip": "^6.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.20.6",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "flatted": ">=3.4.2",
    "path-to-regexp": ">=8.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "path-to-regexp": ">=8.4.0"
    }
  }
}
