{
  "name": "risoluto",
  "version": "0.6.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/OmerFarukOruc/risoluto.git"
  },
  "homepage": "https://github.com/OmerFarukOruc/risoluto",
  "bugs": {
    "url": "https://github.com/OmerFarukOruc/risoluto/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "risoluto": "./bin/risoluto"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run build:frontend",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:sqlite": "vitest run --config vitest.integration.config.ts tests/integration/sqlite-*.integration.test.ts",
    "test:integration:contracts": "vitest run --config vitest.integration.config.ts tests/http/*-contracts.integration.test.ts",
    "test:integration:live": "vitest run --config vitest.live.config.ts",
    "test:all": "pnpm test && pnpm run test:integration && pnpm exec playwright test --project=smoke",
    "test:docker": "vitest run tests/integration/docker-lifecycle.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project=smoke",
    "test:e2e:visual": "playwright test --project=visual",
    "test:e2e:fullstack": "playwright test --config playwright.fullstack.config.ts",
    "test:e2e:update": "playwright test --project=visual --update-snapshots",
    "test:frontend": "vitest run --config vitest.frontend.config.ts",
    "test:load": "vitest run --config vitest.load.config.ts",
    "dev": "tsx watch src/cli/index.ts",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "lint": "eslint src/ tests/ playwright.config.ts playwright.fullstack.config.ts",
    "lint:fix": "eslint --fix src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts' '*.json' 'playwright.config.ts' 'playwright.fullstack.config.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts' 'playwright.config.ts' 'playwright.fullstack.config.ts'",
    "knip": "knip",
    "circular": "madge --circular --extensions ts,tsx src/ frontend/src/",
    "docs:generate": "typedoc",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:tests": "tsc --noEmit -p tsconfig.typecheck.json",
    "typecheck:coverage": "type-coverage --at-least 95 --detail --strict --ignore-catch",
    "typecheck:frontend": "tsc --noEmit -p frontend/tsconfig.json",
    "prepare": "husky"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "chokidar": "^5.0.0",
    "drizzle-orm": "^0.45.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "liquidjs": "^10.25.5",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/autocannon": "^7.12.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "agentation": "^3.0.2",
    "agentation-mcp": "^1.2.0",
    "ajv": "^8.18.0",
    "autocannon": "^8.0.0",
    "codemirror": "^6.0.2",
    "eslint": "^10.2.0",
    "fast-check": "^4.6.0",
    "husky": "^9.1.7",
    "knip": "^6.4.1",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "semantic-release": "^25.0.3",
    "tsx": "^4.20.6",
    "type-coverage": "^2.29.7",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "flatted": ">=3.4.2",
    "hono": ">=4.12.12",
    "@hono/node-server": ">=1.19.13",
    "path-to-regexp": ">=8.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "hono": ">=4.12.12",
      "@hono/node-server": ">=1.19.13",
      "path-to-regexp": ">=8.4.0"
    }
  }
}
