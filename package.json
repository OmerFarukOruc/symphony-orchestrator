{
  "name": "symphony-orchestrator",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/OmerFarukOruc/symphony-orchestrator.git"
  },
  "homepage": "https://github.com/OmerFarukOruc/symphony-orchestrator",
  "bugs": {
    "url": "https://github.com/OmerFarukOruc/symphony-orchestrator/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "symphony": "./bin/symphony"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:frontend",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:docker": "vitest run tests/integration/docker-lifecycle.test.ts",
    "test:e2e": "vitest run tests/integration/e2e-smoke.test.ts",
    "dev": "tsx watch src/cli/index.ts",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint --fix src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts' '*.json'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "knip": "knip",
    "jscpd": "jscpd --config .jscpd.json",
    "docs:generate": "typedoc",
    "typecheck:frontend": "tsc --noEmit -p frontend/tsconfig.json",
    "prepare": "husky"
  },
  "dependencies": {
    "agentation-mcp": "^1.2.0",
    "chokidar": "^5.0.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.1",
    "liquidjs": "^10.24.0",
    "winston": "^3.18.3",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.0",
    "agentation": "^2.3.3",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "knip": "^5.87.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.20.6",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "flatted": ">=3.4.2"
  }
}
