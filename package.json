{
  "name": "symphony-orchestrator",
  "version": "0.4.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/OmerFarukOruc/symphony-orchestrator.git"
  },
  "homepage": "https://github.com/OmerFarukOruc/symphony-orchestrator",
  "bugs": {
    "url": "https://github.com/OmerFarukOruc/symphony-orchestrator/issues"
  },
  "packageManager": "pnpm@10.17.1",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "symphony": "./bin/symphony"
  },
  "scripts": {
    "build": "pnpm run build:shared && pnpm run build:backend && pnpm run build:frontend",
    "build:backend": "pnpm --filter @symphony/backend build",
    "build:frontend": "pnpm --filter @symphony/frontend build:react",
    "build:frontend:legacy": "pnpm --filter @symphony/frontend build:vanilla",
    "build:shared": "pnpm --filter @symphony/shared build",
    "test": "pnpm exec vitest run",
    "test:watch": "pnpm exec vitest",
    "test:integration": "pnpm exec vitest run --config vitest.integration.config.ts",
    "test:docker": "pnpm exec vitest run tests/integration/docker-lifecycle.test.ts",
    "test:e2e": "pnpm exec playwright test",
    "test:e2e:smoke": "pnpm exec playwright test --project=smoke",
    "test:e2e:visual": "pnpm exec playwright test --project=visual",
    "test:e2e:update": "pnpm exec playwright test --project=visual --update-snapshots",
    "test:e2e:legacy": "pnpm exec vitest run tests/integration/e2e-smoke.test.ts",
    "dev": "pnpm --filter @symphony/backend dev",
    "dev:frontend": "pnpm --filter @symphony/frontend dev:react",
    "dev:frontend:legacy": "pnpm --filter @symphony/frontend dev:vanilla",
    "lint": "pnpm exec eslint src/ tests/ packages/ frontend/*.ts playwright.config.ts",
    "lint:fix": "pnpm exec eslint --fix src/ tests/ packages/ frontend/*.ts",
    "format": "pnpm exec prettier --write 'src/**/*.ts' 'tests/**/*.ts' 'frontend/*.ts' 'packages/**/*.{ts,json}' '*.json' 'playwright.config.ts'",
    "format:check": "pnpm exec prettier --check 'src/**/*.ts' 'tests/**/*.ts' 'frontend/*.ts' 'packages/**/*.{ts,json}' '*.json' 'playwright.config.ts'",
    "knip": "pnpm exec knip",
    "jscpd": "pnpm exec jscpd --config .jscpd.json",
    "docs:generate": "pnpm exec typedoc",
    "typecheck:frontend": "pnpm --filter @symphony/frontend typecheck:vanilla",
    "prepare": "pnpm exec husky"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@sinclair/typebox": "^0.34.41",
    "@tanstack/react-query": "^5.90.5",
    "agentation-mcp": "^1.2.0",
    "better-sqlite3": "^12.4.1",
    "chokidar": "^5.0.0",
    "drizzle-orm": "^0.44.6",
    "express": "^5.1.0",
    "fastify": "^5.6.1",
    "liquidjs": "^10.25.1",
    "pino": "^10.1.0",
    "prom-client": "^15.1.3",
    "react-router-dom": "^7.9.4",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.0",
    "agentation": "^2.3.3",
    "eslint": "^10.1.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "knip": "^6.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.20.6",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "flatted": ">=3.4.2"
  }
}
