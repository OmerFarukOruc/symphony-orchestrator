{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "project": [
    "src/**/*.ts",
    "frontend/**/*.ts",
    "tests/**/*.ts"
  ],
  "entry": [
    "src/dispatch/entrypoint.ts"
  ],
  "ignore": [
    ".github/**",
    ".husky/**"
  ],
  "ignoreFiles": [
    "frontend/src/components/issue-card.ts",
    "frontend/src/pages/page-factory.ts",
    "frontend/src/utils/escape.ts"
  ],
  "ignoreExportsUsedInFile": true,
  "ignoreBinaries": [
    "eslint",
    "husky",
    "jscpd",
    "knip",
    "lint-staged",
    "prettier",
    "tsc",
    "tsx",
    "typedoc",
    "vite",
    "vitest"
  ],
  "ignoreDependencies": [
    "agentation-mcp",
    "eslint",
    "husky",
    "jscpd",
    "lint-staged",
    "prettier",
    "tsx",
    "typedoc"
  ]
}
