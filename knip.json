{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    ".": {
      "entry": ["src/cli/index.ts", "src/dispatch/entrypoint.ts"],
      "project": ["src/**/*.ts", "tests/**/*.ts"],
      "ignoreFiles": ["tests/e2e/**"]
    },
    "packages/shared": {
      "project": ["src/**/*.ts"]
    },
    "packages/frontend": {
      "project": ["src/**/*.ts", "src/**/*.tsx", "scripts/**/*.ts"],
      "ignoreFiles": ["src/generated/**", "src/app-shell/PlaceholderRoute.tsx", "src/hooks/use-polling-invalidation.ts"]
    },
    "packages/backend": {
      "project": ["src/**/*.ts"]
    }
  },
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": [
    "agentation-mcp",
    "agentation",
    "react",
    "react-dom",
    "@tanstack/react-query",
    "react-router-dom",
    "@fastify/cors",
    "@fastify/rate-limit",
    "@fastify/static",
    "@fastify/swagger",
    "@symphony/shared",
    "better-sqlite3",
    "drizzle-orm",
    "fastify",
    "fast-json-stringify",
    "pino",
    "pino-pretty",
    "prom-client"
  ],
  "ignoreFiles": ["packages/shared/src/**/*.ts", "packages/frontend/src/generated/**"]
}
