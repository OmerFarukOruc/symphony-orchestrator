{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "project": ["src/**/*.ts", "frontend/**/*.ts", "tests/**/*.ts"],
  "entry": ["src/dispatch/entrypoint.ts"],
  "ignore": [
    "frontend/src/pages/page-factory.ts",
    "tests/e2e/**",
    "src/config/index.ts",
    "src/dispatch/index.ts",
    "src/git/index.ts",
    "src/orchestrator/index.ts",
    "src/tracker/index.ts",
    "src/workspace/index.ts"
  ],
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": [
    "agentation-mcp",
    "@stryker-mutator/core",
    "eslint",
    "husky",
    "jscpd",
    "lint-staged",
    "prettier",
    "tsx",
    "typedoc"
  ],
  "ignoreBinaries": [
    "knip",
    "jscpd",
    "playwright",
    "lint-staged",
    "eslint",
    "prettier",
    "stryker",
    "tsc",
    "vite",
    "vitest",
    "tsx",
    "typedoc",
    "husky"
  ]
}
