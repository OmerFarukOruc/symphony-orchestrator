# === Host paths (required) ===
SYMPHONY_HOST_WORKSPACE_ROOT=/home/user/symphony/workspaces
SYMPHONY_HOST_ARCHIVE_DIR=/home/user/symphony/archives
CODEX_AUTH_SOURCE_HOME=/home/user/.codex

# === API Keys (required) ===
LINEAR_API_KEY=lin_api_...
LINEAR_PROJECT_SLUG=example-project
MASTER_KEY=replace-with-a-strong-secret

# === Optional: Provider credentials ===
OPENAI_API_KEY=
GITHUB_TOKEN=

# === Optional: Control/Data Plane dispatch mode ===
# Set DISPATCH_MODE=remote to enable control/data plane split.
# Default is "local" (single-process mode).
DISPATCH_MODE=local
DISPATCH_URL=http://data-plane:9100/dispatch
DISPATCH_SHARED_SECRET=

# === Optional: Cloudflare Tunnel (webhook exposure) ===
># Tunnel: <your-tunnel-id>
># DNS: <your-tunnel-domain> → tunnel
# Set webhook_url in workflow config to: https://webhooks.risolu.to/webhooks/linear
CLOUDFLARE_TUNNEL_TOKEN=REDACTED_ROTATE_THIS_TOKEN