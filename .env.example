# Keep infrastructure-level secrets here (.env should stay local and gitignored).
# App credentials such as LINEAR_API_KEY / OPENAI_API_KEY can also be entered
# via the setup wizard and stored in Risoluto's encrypted secrets store.

# === Host paths (required for bind-mounted Docker deployments) ===
RISOLUTO_HOST_WORKSPACE_ROOT=/home/user/risoluto/workspaces
RISOLUTO_HOST_ARCHIVE_DIR=/home/user/risoluto/archives
CODEX_AUTH_SOURCE_HOME=/home/user/.codex

# === API Keys (required) ===
LINEAR_API_KEY=lin_api_...
LINEAR_PROJECT_SLUG=example-project
MASTER_KEY=replace-with-a-strong-secret

# === Optional: Provider credentials ===
OPENAI_API_KEY=
GITHUB_TOKEN=

# === Optional: Admin API hardening ===
RISOLUTO_WRITE_TOKEN=

# === Optional: Control/Data Plane dispatch mode ===
# Set DISPATCH_MODE=remote to enable control/data plane split.
# Default is "local" (single-process mode).
DISPATCH_MODE=local
DISPATCH_URL=http://data-plane:9100/dispatch
DISPATCH_SHARED_SECRET=

# === Optional: Cloudflare Tunnel (webhook exposure) ===
# Set webhook_url in config overlay to: https://<your-tunnel>.trycloudflare.com/webhooks/linear
CLOUDFLARE_TUNNEL_TOKEN=
