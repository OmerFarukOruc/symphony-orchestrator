{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-core.schema.json",
  "plugins": ["@stryker-mutator/vitest-runner", "@stryker-mutator/typescript-checker"],
  "testRunner": "vitest",
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "mutate": [
    "src/config/builders.ts",
    "src/config/coercion.ts",
    "src/config/merge.ts",
    "src/config/normalizers.ts",
    "src/config/overlay-helpers.ts",
    "src/config/resolvers.ts",
    "src/config/validators.ts",

    "src/core/attempt-store.ts",
    "src/core/attempt-store-port.ts",
    "src/core/content-sanitizer.ts",
    "src/core/model-pricing.ts",
    "src/core/signal-detection.ts",

    "src/state/machine.ts",
    "src/state/policy.ts",

    "src/agent-runner/abort-outcomes.ts",
    "src/agent-runner/error-classifier.ts",
    "src/agent-runner/exit-classifier.ts",
    "src/agent-runner/helpers.ts",
    "src/agent-runner/model-validation.ts",
    "src/agent-runner/turn-executor.ts",
    "src/agent-runner/turn-state.ts",

    "src/orchestrator/dispatch.ts",
    "src/orchestrator/git-post-run.ts",
    "src/orchestrator/issue-locator.ts",
    "src/orchestrator/issue-view-builders.ts",
    "src/orchestrator/lifecycle.ts",
    "src/orchestrator/model-selection.ts",
    "src/orchestrator/outcome-view-builder.ts",
    "src/orchestrator/retry-failure.ts",
    "src/orchestrator/retry-manager.ts",
    "src/orchestrator/snapshot-builder.ts",
    "src/orchestrator/stall-detector.ts",
    "src/orchestrator/views.ts",
    "src/orchestrator/worker-failure.ts",

    "src/utils/type-guards.ts",
    "src/workspace/manager.ts",
    "src/workspace/path-registry.ts",
    "src/workspace/paths.ts",

    "src/workflow/columns.ts",
    "src/workflow/loader.ts",

    "src/git/manager.ts",
    "src/git/repo-router.ts",
    "src/git/github-pr-client.ts",

    "src/linear/client.ts",
    "src/linear/errors.ts",
    "src/linear/issue-pagination.ts",
    "src/linear/issue-parser.ts",

    "src/http/attempt-handler.ts",
    "src/http/model-handler.ts",
    "src/http/route-helpers.ts",
    "src/http/routes.ts",
    "src/http/sse.ts",
    "src/http/transition-handler.ts",
    "src/http/transitions-api.ts",
    "src/http/validation.ts",
    "src/http/webhook-handler.ts",
    "src/http/workspace-inventory.ts",
    "src/http/write-guard.ts",

    "src/persistence/sqlite/attempt-store-sqlite.ts",
    "src/persistence/sqlite/issue-config-store.ts",
    "src/persistence/sqlite/mappers.ts",
    "src/persistence/sqlite/migrator.ts",
    "src/persistence/sqlite/webhook-inbox.ts",

    "src/secrets/db-store.ts",

    "src/notification/manager.ts",

    "src/setup/detect-default-branch.ts",
    "src/setup/setup-status.ts",

    "src/webhook/health-tracker.ts"
  ],
  "incremental": true,
  "incrementalFile": "reports/stryker-incremental.json",
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 70
  },
  "reporters": ["html", "clear-text", "progress"],
  "htmlReporter": {
    "fileName": "reports/stryker-report.html"
  },
  "timeoutMS": 60000,
  "concurrency": 4,
  "ignorePatterns": [".agents", ".claude", "docs", "skills", "dist", "frontend", "reports"]
}
